{
  "expo": {
    "name": "FindEat",
    "slug": "mobile",
    "scheme": "findeat",
    "version": "1.5.5",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "FindEat uses your camera so you can capture food posts and profile photos.",
        "NSPhotoLibraryUsageDescription": "FindEat uses your photo library so you can choose photos for posts and your profile."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "@rnmapbox/maps",
      "expo-font",
      "expo-image",
      "expo-status-bar",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "defaultChannel": "findeat-alerts"
        }
      ],
      "expo-camera",
      [
        "expo-image-picker",
        {
          "photosPermission": "FindEat uses your photo library so you can choose photos for posts, reviews, dishes, and your profile.",
          "cameraPermission": "FindEat uses your camera so you can capture photos for posts and reviews."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "FindEat uses your location to show nearby restaurants and calculate distance."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d019d88c-bba2-4463-b8ce-cff209e68451"
      }
    }
  }
}
