{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "paths": {
      "@/*": ["./*"],
      "@findeat/types": ["../../packages/types/index.ts"],
      "@findeat/types/*": ["../../packages/types/*"],
      "@findeat/utils/*": ["../../packages/utils/*"],
      "@findeat/api": ["../../packages/api/index.ts"],
      "@findeat/api/*": ["../../packages/api/*"]
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
