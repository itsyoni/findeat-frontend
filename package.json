{
  "name": "findeat-frontend",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "mobile": "npm --workspace apps/mobile run start",
    "mobile:dev-client": "npm --workspace apps/mobile run start:dev-client",
    "mobile:clean": "npm --workspace apps/mobile run start:clean",
    "web": "npm --workspace apps/web run dev",
    "build:web": "npm --workspace apps/web run build",
    "typecheck:mobile": "npm --workspace apps/mobile run typecheck",
    "typecheck:web": "npm --workspace apps/web run typecheck",
    "lint:mobile": "npm --workspace apps/mobile run lint",
    "lint:web": "npm --workspace apps/web run lint",
    "typecheck": "npm run typecheck:mobile && npm run typecheck:web",
    "lint": "npm run lint:mobile && npm run lint:web",
    "version:check": "node scripts/mobile-version.mjs check",
    "version:patch": "node scripts/mobile-version.mjs patch",
    "version:minor": "node scripts/mobile-version.mjs minor",
    "version:major": "node scripts/mobile-version.mjs major",
    "version:set": "node scripts/mobile-version.mjs set",
    "mobile:build:dev:ios": "npm --workspace apps/mobile run build:dev:ios",
    "build:dev:ios": "npm --workspace apps/mobile run build:dev:ios",
    "mobile:build:dev:android": "npm --workspace apps/mobile run build:dev:android",
    "build:dev:android": "npm --workspace apps/mobile run build:dev:android",
    "mobile:build:dev:all": "npm --workspace apps/mobile run build:dev:all",
    "build:dev:all": "npm --workspace apps/mobile run build:dev:all",
    "mobile:build:preview:ios": "npm --workspace apps/mobile run build:preview:ios",
    "build:preview:ios": "npm --workspace apps/mobile run build:preview:ios",
    "mobile:build:preview:android": "npm --workspace apps/mobile run build:preview:android",
    "build:preview:android": "npm --workspace apps/mobile run build:preview:android",
    "mobile:build:preview:all": "npm --workspace apps/mobile run build:preview:all",
    "build:preview:all": "npm --workspace apps/mobile run build:preview:all",
    "mobile:build:prod:ios": "npm --workspace apps/mobile run build:prod:ios",
    "build:prod:ios": "npm --workspace apps/mobile run build:prod:ios",
    "mobile:build:prod:android": "npm --workspace apps/mobile run build:prod:android",
    "build:prod:android": "npm --workspace apps/mobile run build:prod:android",
    "mobile:build:prod:all": "npm --workspace apps/mobile run build:prod:all",
    "build:prod:all": "npm --workspace apps/mobile run build:prod:all",
    "mobile:build:prod:ios:submit": "npm --workspace apps/mobile run build:prod:ios:submit",
    "build:prod:ios:submit": "npm --workspace apps/mobile run build:prod:ios:submit",
    "mobile:build:prod:android:submit": "npm --workspace apps/mobile run build:prod:android:submit",
    "build:prod:android:submit": "npm --workspace apps/mobile run build:prod:android:submit",
    "mobile:submit:ios:latest": "npm --workspace apps/mobile run submit:ios:latest",
    "submit:ios:latest": "npm --workspace apps/mobile run submit:ios:latest",
    "mobile:submit:android:latest": "npm --workspace apps/mobile run submit:android:latest",
    "submit:android:latest": "npm --workspace apps/mobile run submit:android:latest"
  },
  "overrides": {
    "lightningcss": "1.30.1"
  }
}
