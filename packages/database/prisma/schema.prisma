generator client {
  provider = "prisma-client"
  output   = "../generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                       String                    @id @default(cuid())
  email                    String                    @unique
  username                 String                    @unique
  phoneNumber              String?                   @unique
  displayName              String
  bio                      String?
  profilePictureUrl        String?
  password                 String
  gender                   String?
  pronouns                 String?
  role                     UserRole                  @default(USER)
  reviews                  Review[]
  followers                Follow[]                  @relation("Following")
  following                Follow[]                  @relation("Follower")
  likedReviews             ReviewLike[]
  savedReviews             SavedReview[]
  comments                 Comment[]
  restaurantMemberships    RestaurantMember[]
  invitedRestaurantMembers RestaurantMember[]        @relation("RestaurantMemberInvitedBy")
  receivedNotifications    Notification[]            @relation("NotificationRecipient")
  sentNotifications        Notification[]            @relation("NotificationSender")
  conversations            ConversationParticipant[]
  messages                 Message[]
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
}

model Follow {
  id          String   @id @default(cuid())
  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  followerId  String
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)
  followingId String
  createdAt   DateTime @default(now())

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model Review {
  id            String         @id @default(cuid())
  title         String
  description   String?
  coverImageUrl String?
  overallRating Int?
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  restaurant    Restaurant?    @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  restaurantId  String?
  items         ReviewItem[]
  likes         ReviewLike[]
  saves         SavedReview[]
  comments      Comment[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([authorId])
  @@index([restaurantId])
  @@index([createdAt])
}

model ReviewItem {
  id          String   @id @default(cuid())
  review      Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId    String
  name        String
  description String?
  imageUrl    String?
  rating      Int?
  price       Decimal? @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([reviewId])
}

model Restaurant {
  id            String             @id @default(cuid())
  name          String
  description   String?
  coverImageUrl String?
  address       String?
  city          String?
  latitude      Float?
  longitude     Float?
  isClaimed     Boolean            @default(false)
  isVerified    Boolean            @default(false)
  reviews       Review[]
  members       RestaurantMember[]
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@index([latitude, longitude])
}

model RestaurantMember {
  id           String         @id @default(cuid())
  user         User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  restaurant   Restaurant     @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  restaurantId String
  role         RestaurantRole @default(STAFF)
  isVerified   Boolean        @default(false)
  badgeVisible Boolean        @default(true)
  verifiedAt   DateTime?
  invitedBy    User?          @relation("RestaurantMemberInvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedById  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  @@unique([userId, restaurantId])
  @@index([userId])
  @@index([restaurantId])
  @@index([invitedById])
}

model ReviewLike {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
}

model SavedReview {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  review    Review   @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId  String
  createdAt DateTime @default(now())

  @@unique([userId, reviewId])
  @@index([userId])
  @@index([reviewId])
}

model Comment {
  id            String         @id @default(cuid())
  content       String
  author        User           @relation(fields: [authorId], references: [id], onDelete: Cascade)
  authorId      String
  review        Review         @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId      String
  parent        Comment?       @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  parentId      String?
  replies       Comment[]      @relation("CommentReplies")
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([authorId])
  @@index([reviewId])
  @@index([parentId])
}

model Notification {
  id          String           @id @default(cuid())
  recipient   User             @relation("NotificationRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String
  sender      User?            @relation("NotificationSender", fields: [senderId], references: [id], onDelete: Cascade)
  senderId    String?
  type        NotificationType
  review      Review?          @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  reviewId    String?
  comment     Comment?         @relation(fields: [commentId], references: [id], onDelete: Cascade)
  commentId   String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt, createdAt])
  @@index([senderId])
  @@index([reviewId])
  @@index([commentId])
}

model Conversation {
  id           String                    @id @default(cuid())
  isGroup      Boolean                   @default(false)
  name         String?
  imageUrl     String?
  participants ConversationParticipant[]
  messages     Message[]
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
}

model ConversationParticipant {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  role           String?
  joinedAt       DateTime     @default(now())
  lastReadAt     DateTime?

  @@unique([conversationId, userId])
  @@index([userId])
  @@index([conversationId])
}

model Message {
  id             String       @id @default(cuid())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  conversationId String
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)
  senderId       String
  content        String?
  type           MessageType  @default(TEXT)
  clientId       String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([conversationId, senderId, clientId])
  @@index([conversationId, createdAt])
  @@index([senderId])
}

enum MessageType {
  TEXT
  IMAGE
  SYSTEM
}

enum NotificationType {
  FOLLOW
  LIKE_REVIEW
  COMMENT_REVIEW
  REPLY_COMMENT
}

enum UserRole {
  USER
  ADMIN
}

enum RestaurantRole {
  OWNER
  MANAGER
  CONTENT_MANAGER
  STAFF
}
